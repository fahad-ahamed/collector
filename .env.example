# Collector - Environment Configuration
# Copy this file to .env and customize for your server

# Database URL (kept for compatibility, not actively used - file-based DB in ./db folder)
DATABASE_URL="file:./dev.db"

# File upload directory (defaults to /tmp/collector-uploads if not set)
# UPLOAD_DIR="/tmp/collector-uploads"

# Database directory for JSON file storage (defaults to ./db if not set)
# DB_DIR="./db"

# Java/JDK Configuration (auto-detected if not set)
# JAVA_HOME=/usr/lib/jvm/java-21-openjdk-amd64
# JAVAC_PATH=/usr/lib/jvm/java-21-openjdk-amd64/bin/javac

# Android SDK Configuration (auto-detected if not set)
# ANDROID_HOME=/home/user/android-sdk

# Server URL (for APK to connect back to this server)
# Only needed if auto-detection from request headers fails
# Format: http://YOUR_SERVER_IP or https://yourdomain.com
# SERVER_URL=http://1.2.3.4

# Master Code for accessing all sessions (auto-generated if not set)
# MASTER_CODE=32423

# Deploy token for the /api/deploy endpoint
# DEPLOY_TOKEN=collector-deploy-2026

# Project directory (defaults to current working directory)
# PROJECT_DIR=/path/to/collector

