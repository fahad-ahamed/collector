generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model ContactSession {
  id        String   @id @default(cuid())
  contacts  String   // JSON array of contacts
  files     String   @default("[]") // JSON array of file metadata
  appName   String   @default("Collector")
  count     Int      @default(0)
  fileCount Int      @default(0)
  createdAt DateTime @default(now())

  uploadedFiles UploadedFile[]
}

model UploadedFile {
  id         String   @id @default(cuid())
  sessionId  String
  filePath   String   // Original path on phone
  fileName   String
  fileSize   Int      @default(0)
  fileType   String   @default("other") // mime type or category
  serverPath String   // Relative path on server filesystem under /home/z/my-project/uploaded-files/
  uploadedAt DateTime @default(now())

  session    ContactSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}
